{
    "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "moduleResolution": "Node",
      "lib": ["ES2020"],
      "outDir": "dist-server",
      "rootDir": ".",
      "strict": false,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "types": ["node"]
    },
    "include": ["server.ts"]
  }